generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?   // For credentials provider
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reputation    Int       @default(0)

  // Relations
  accounts   Account[]
  trades     Trade[]
  strategies Strategy[]
  settings   Settings?
  tags       Tag[]
  syncRequests SyncRequest[]
  posts      Post[]
  reactions  Reaction[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  // Broker connection fields
  brokerName        String? // e.g., "metaTrader4", "metaTrader5", "cTrader"
  accountNumber     String?
  accountBalance    Float?
  accountCurrency   String?  @default("USD")
  isDemo            Boolean? @default(false)
  isActive          Boolean  @default(true)
  lastSyncAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Trade {
  id                  String    @id @default(cuid())
  userId              String
  accountId           String?
  
  // Trade Identification
  ticketId            String?   @unique
  symbol              String
  type                String    // BUY or SELL
  
  // Entry/Exit Details
  entryPrice          Float
  exitPrice           Float?
  entryDate           DateTime
  exitDate            DateTime?
  
  // Position Details
  quantity            Float
  stopLoss            Float?
  takeProfit          Float?
  
  // Financial Results
  pnl                 Float?
  pnlPercentage       Float?
  commission          Float?    @default(0)
  swap                Float?    @default(0)
  fees                Float?    @default(0)
  netPnl              Float?
  
  // Risk Management
  riskAmount          Float?
  riskPercentage      Float?
  rMultiple           Float?
  
  // Trade Status
  status              String    @default("OPEN") // OPEN, CLOSED, CANCELLED, PENDING
  
  // Analysis Fields
  strategyId          String?
  setupType           String?
  marketCondition     String?   // TRENDING_UP, TRENDING_DOWN, RANGING, VOLATILE, BREAKOUT, REVERSAL
  entryEmotion        String?   // CONFIDENT, FEARFUL, GREEDY, IMPATIENT, NEUTRAL, FRUSTRATED, EXCITED, CAUTIOUS
  exitEmotion         String?   // CONFIDENT, FEARFUL, GREEDY, IMPATIENT, NEUTRAL, FRUSTRATED, EXCITED, CAUTIOUS
  
  // Trade Notes
  preTradeAnalysis    String?
  postTradeAnalysis   String?
  lessonsLearned      String?
  emotions            String?
  rating              Int?
  executionChecklist  String?
  
  // Metadata
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account?     @relation(fields: [accountId], references: [id])
  strategy    Strategy?    @relation(fields: [strategyId], references: [id])
  screenshots Screenshot[]
  tags        TradeTag[]
  partialCloses PartialClose[]
  posts       Post[]
  
  @@index([userId])
  @@index([symbol])
  @@index([entryDate])
  @@index([status])
  @@index([strategyId])
  @@map("trades")
}

model Tag {
  id          String   @id @default(cuid())
  userId      String
  name        String
  color       String   @default("#3b82f6") // Default blue
  description String?
  createdAt   DateTime @default(now())
  
  // Relations
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades TradeTag[]
  
  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model TradeTag {
  id        String   @id @default(cuid())
  tradeId   String
  tagId     String
  createdAt DateTime @default(now())
  
  // Relations
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([tradeId, tagId])
  @@index([tradeId])
  @@index([tagId])
  @@map("trade_tags")
}

model PartialClose {
  id            String   @id @default(cuid())
  tradeId       String
  quantity      Float    // Lots/quantity closed
  exitPrice     Float    // Price at partial close
  pnl           Float?   // Calculated P&L for this partial
  closedAt      DateTime @default(now())
  notes         String?

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@map("partial_closes")
}

model Screenshot {
  id          String   @id @default(cuid())
  tradeId     String
  url         String
  caption     String?
  chartType   String?   // ENTRY, EXIT, ANALYSIS, SETUP
  createdAt   DateTime @default(now())
  
  // Relations
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  
  @@index([tradeId])
  @@map("screenshots")
}

model Strategy {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  rules       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]
  
  @@index([userId])
  @@map("strategies")
}

model Settings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  
  // Account Settings
  accountBalance        Float?   // Opening / starting account balance in USD

  // Display Settings
  theme                 String   @default("dark") // dark, light, system
  currency              String   @default("USD")
  dateFormat            String   @default("MM/dd/yyyy")
  timezone              String   @default("UTC")
  
  // Trade Display Settings
  defaultTradeView      String   @default("list") // list, grid, calendar
  tradesPerPage         Int      @default(25)
  showClosedTrades      Boolean  @default(true)
  showOpenTrades        Boolean  @default(true)
  
  // Dashboard Settings
  defaultDashboardView  String   @default("overview") // overview, analytics, calendar
  favoriteSymbols       String   @default("") // Comma-separated for SQLite
  
  // Notification Settings
  emailNotifications    Boolean  @default(true)
  tradeAlerts           Boolean  @default(true)
  weeklyReports         Boolean  @default(true)
  
  // Privacy Settings
  publicProfile         Boolean  @default(false)
  shareAnalytics        Boolean  @default(false)
  showOnLeaderboard     Boolean  @default(true)
  showTrades            Boolean  @default(false)

  // Trade Display Settings (Additional)
  showPnlPerTrade       Boolean  @default(true)
  showTotalPnl          Boolean  @default(true)
  showWinRate           Boolean  @default(true)
  showTradeCount        Boolean  @default(true)
  
  // Notification Settings (Additional)
  pushNotifications     Boolean  @default(false)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("settings")
}

model SyncRequest {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "COUNT", "DATE", "ALL"
  value     String   // e.g., "10", "2024-01-01", "ALL"
  status    String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("sync_requests")
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  content   String
  tradeId   String?  // Optional Reference to a Trade
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trade     Trade?   @relation(fields: [tradeId], references: [id], onDelete: SetNull)
  reactions Reaction[]

  @@index([userId])
  @@index([createdAt])
  @@map("posts")
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  type      String   // "BULLISH" or "BEARISH"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("reactions")
}
