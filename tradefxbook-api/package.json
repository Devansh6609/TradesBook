{
  "name": "tradesbook-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute tradesbook-db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute tradesbook-db --remote --file=./schema.sql",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.2.5",
    "jose": "^5.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240329.0",
    "typescript": "^5.4.4",
    "wrangler": "^3.51.2"
  }
}
